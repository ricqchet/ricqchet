# Monorepo root .gitignore — shared OS / editor / workspace noise only.
# Per-project build artifacts live in each subproject's own .gitignore:
#   ricqchet-web/.gitignore        (Elixir / Phoenix)
#   ricqchet-ts-client/.gitignore  (Node / TypeScript)

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Temporary files
tmp/

# Stray BEAM crash dumps. Project artifacts live in each subproject's
# .gitignore, but a dump lands at the repo root if BEAM is run from here.
erl_crash.dump
*.dump

# Conductor workspace context
.context/
