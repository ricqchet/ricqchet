{
  "name": "@ricqchet/client",
  "version": "0.1.0",
  "description": "TypeScript client for Ricqchet — HTTP message queue, webhooks, and real-time channels",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./realtime": {
      "import": {
        "types": "./dist/realtime.d.mts",
        "default": "./dist/realtime.mjs"
      },
      "require": {
        "types": "./dist/realtime.d.ts",
        "default": "./dist/realtime.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.mts",
        "default": "./dist/next.mjs"
      },
      "require": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ricqchet",
    "message-queue",
    "webhook",
    "http",
    "realtime",
    "websocket",
    "channels",
    "presence",
    "pusher",
    "phoenix",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricqchet/ricqchet.git",
    "directory": "ricqchet-ts-client"
  },
  "homepage": "https://github.com/ricqchet/ricqchet/tree/main/ricqchet-ts-client#readme",
  "bugs": {
    "url": "https://github.com/ricqchet/ricqchet/issues"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/phoenix": "^1.6.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "happy-dom": "^20.10.2",
    "msw": "^2.1.0",
    "phoenix": "^1.8.7",
    "prettier": "^3.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "phoenix": "^1.7.0 || ^1.8.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "phoenix": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
